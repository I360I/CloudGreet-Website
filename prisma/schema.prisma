generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String
  companyName      String?
  phoneNumber      String?
  subscriptionPlan String   @default("basic")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  settings         UserSettings?
  callLogs         CallLog[]
  bookings         Booking[]
  goals            UserGoal[]

  @@map("users")
}

model UserSettings {
  id                String @id @default(cuid())
  userId            String @unique
  businessHours     Json?
  greetingMessage   String?
  zapierWebhookUrl  String?
  
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model CallLog {
  id           String   @id @default(cuid())
  userId       String
  callerPhone  String?
  callDuration Int?
  callOutcome  String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking      Booking?

  @@map("call_logs")
}

model Booking {
  id            String    @id @default(cuid())
  userId        String
  callLogId     String?   @unique
  customerName  String
  serviceType   String
  bookingValue  Decimal
  status        String    @default("pending")
  scheduledDate DateTime?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  callLog       CallLog?  @relation(fields: [callLogId], references: [id])

  @@map("bookings")
}

model UserGoal {
  id           String  @id @default(cuid())
  userId       String
  goalType     String
  title        String
  description  String?
  icon         String  @default("🎯")
  targetValue  Decimal
  currentValue Decimal @default(0)
  unit         String  @default("$")
  createdAt    DateTime @default(now())

  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_goals")
}
